{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Anmar Bid Pro default capabilities",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-save",
    "dialog:allow-open",
    "fs:default",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-app-read",
    "fs:allow-app-write",
    "fs:scope-app-recursive",
    "fs:scope-document-recursive",
    "fs:scope-download-recursive",
    "fs:scope-desktop-recursive",
    "fs:scope-home-recursive",
    "sql:default",
    "sql:allow-load",
    "sql:allow-select",
    "sql:allow-execute",
    "sql:allow-close"
  ]
}
